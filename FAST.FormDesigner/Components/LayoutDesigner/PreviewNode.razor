@using FAST.FormDesigner.Runtime.Models
@using FAST.FormDesigner.Runtime.Services

@if (Container is null) { return; }

@switch (Container.Type)
{
    // ── AREA ─────────────────────────────────────────────────────────────────
    case ContainerType.Area:
    {
        var area = Container.Area;
        <div class="fd-pv-area fd-col-@((int)Container.ColumnSpan)">
            @if (!string.IsNullOrWhiteSpace(Container.Label))
            {
                <div class="fd-pv-area-label">@Container.Label</div>
            }
            @if (area is not null && !string.IsNullOrWhiteSpace(area.AssignedFragmentId))
            {
                <FragmentRenderer FragmentId="@area.AssignedFragmentId"
                              InstanceKey="@(area.DataKey ?? area.AssignedFragmentId)" />
            }
            else
            {
                <div class="fd-pv-area-empty">
                    <span class="fd-pv-empty-icon">⬚</span>
                    <span class="fd-pv-empty-text">@(area?.PlaceholderHint ?? "No fragment assigned")</span>
                </div>
            }
        </div>
        break;
    }

    // ── GROUP ─────────────────────────────────────────────────────────────────
    case ContainerType.Group:
    {
        <div class="fd-pv-group fd-col-@((int)Container.ColumnSpan)">
            @if (!string.IsNullOrWhiteSpace(Container.Label))
            {
                <div class="fd-pv-group-title">@Container.Label</div>
            }
            <div class="fd-node-grid">
                @foreach (var child in Container.Children.OrderBy(c => c.Order))
                {
                    <PreviewNode Container="@child" />
                }
            </div>
        </div>
        break;
    }

    // ── TAB CONTROL ───────────────────────────────────────────────────────────
    case ContainerType.TabControl:
    {
        var tabs = Container.Children
            .Where(c => c.Type == ContainerType.TabPage)
            .OrderBy(c => c.Order).ToList();

        if (!tabs.Any()) break;

        if (string.IsNullOrEmpty(_activeTabId))
            _activeTabId = tabs.First().Id;

        <div class="fd-pv-tabs fd-col-@((int)Container.ColumnSpan)">
            <div class="fd-tab-bar">
                @foreach (var tab in tabs)
                {
                    var t = tab;
                    <button class="fd-tab-btn @(_activeTabId == t.Id ? "active" : "")"
                            @onclick="() => _activeTabId = t.Id">
                        @t.Label
                    </button>
                }
            </div>
            @foreach (var tab in tabs)
            {
                <div class="@(_activeTabId == tab.Id ? "fd-tab-active" : "fd-tab-hidden")">
                    <PreviewNode Container="@tab" />
                </div>
            }
        </div>
        break;
    }

    // ── TAB PAGE ──────────────────────────────────────────────────────────────
    case ContainerType.TabPage:
    {
        <div class="fd-node-grid">
            @foreach (var child in Container.Children.OrderBy(c => c.Order))
            {
                <PreviewNode Container="@child" />
            }
        </div>
        break;
    }
}

@code {
    [Parameter, EditorRequired] public LayoutNode? Container { get; set; }

    private string _activeTabId = string.Empty;

    protected override void OnParametersSet()
    {
        if (Container?.Type == ContainerType.TabControl && string.IsNullOrEmpty(_activeTabId))
        {
            var first = Container.Children
                .Where(c => c.Type == ContainerType.TabPage)
                .OrderBy(c => c.Order)
                .FirstOrDefault();
            if (first is not null) _activeTabId = first.Id;
        }
    }
}
